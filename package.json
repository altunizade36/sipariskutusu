{
  "name": "sipariskutusu",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "admin:dev": "npm --prefix web-admin run dev",
    "admin:build": "npm --prefix web-admin run build",
    "admin:preview": "npm --prefix web-admin run preview",
    "typecheck": "tsc --noEmit",
    "preflight:release": "node scripts/release-preflight.mjs",
    "release:check": "npx expo export --platform web --output-dir dist-ci --clear",
    "release:ready": "npm run typecheck && npm run preflight:release && npm run release:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "infra:check": "node scripts/infra-setup.mjs --check-only",
    "smoke:auth": "node scripts/auth-smoke.mjs",
    "smoke:reactions": "node scripts/reactions-smoke.mjs",
    "smoke:chat": "node scripts/chat-smoke.mjs",
    "smoke:notifications": "node scripts/notifications-smoke.mjs",
    "uat:summary": "node scripts/uat-summary.mjs",
    "infra:auto": "node scripts/infra-setup.mjs",
    "reliability:check": "node scripts/reliability-gate.mjs",
    "system:ready": "node scripts/system-readiness.mjs",
    "release:hardening": "npm run typecheck && npm run test && npm run smoke:reactions && npm run smoke:notifications && npm run infra:check && npm run reliability:check"
  },
  "dependencies": {
    "@expo-google-fonts/cairo": "^0.4.2",
    "@expo-google-fonts/roboto": "^0.4.3",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@replit/revenuecat-sdk": "^4.2.0",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.104.0",
    "expo": "~54.0.34",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-network": "~8.0.8",
    "expo-notifications": "^0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "nativewind": "^4.2.1",
    "posthog-react-native": "^4.42.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.1",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^10.0.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "postcss": "^8.5.13",
    "uuid": "^9.0.1"
  },
  "private": true
}
