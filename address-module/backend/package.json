{
  "name": "@sipariskutusu/backend-performance",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:performance": "tsc -p tsconfig.performance.json",
    "load:performance": "node scripts/load-performance.mjs",
    "load:gate": "node scripts/load-gate.mjs",
    "release:gate": "node scripts/release-gate.mjs",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/cache-manager": "^2.2.2",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "cache-manager": "^5.7.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "ioredis": "^5.4.1",
    "nest-commander": "^3.17.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.24",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
