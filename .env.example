# ============================================================
# SİPARİŞKUTUSU — Ortam Değişkenleri
# Bu dosyayı kopyalayın: cp .env.example .env
# .env dosyasını asla git'e eklemeyin!
# ============================================================

# ─── Supabase (ZORUNLU) ─────────────────────────────────────
# https://supabase.com → Proje Ayarları → API
EXPO_PUBLIC_SUPABASE_URL=https://PROJE_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# PostgreSQL baglanti URL'i (SQL editor / migration araclari icin)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.jvcncrdwikbvvehkimet.supabase.co:5432/postgres

# ─── Supabase Auth (uygulama ayarı) ─────────────────────────
EXPO_PUBLIC_EMAIL_OTP_LENGTH=8

# ─── Medya depolama (opsiyonel) ──────────────────────────────
# supabase: mevcut Supabase storage akisi
# external: backend uzerinden presigned URL ile S3/GCS gibi depolama
EXPO_PUBLIC_MEDIA_STORAGE_MODE=supabase
# Gorsel upload timeout (milisaniye)
EXPO_PUBLIC_IMAGE_UPLOAD_TIMEOUT_MS=20000
# Tek gorsel icin maksimum boyut (byte)
EXPO_PUBLIC_MAX_IMAGE_BYTES=8388608
# Eszamanli gorsel yukleme sayisi (1-8 arasi onerilir)
EXPO_PUBLIC_IMAGE_UPLOAD_CONCURRENCY=2

# ─── Bildirim kanallari (opsiyonel) ─────────────────────────
# Uygulama backend API kullanirken tum kanallar /v1/notifications/dispatch uzerinden gider.
EXPO_PUBLIC_NOTIFICATION_DISPATCH_TIMEOUT_MS=10000

# Edge Function / backend server secretleri (git'e eklemeyin)
# Firebase Cloud Messaging (legacy server key)
FCM_SERVER_KEY=
# SMS API (ornek: netgsm, twilio proxy, yerel SMS gateway)
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=
# Email provider (SendGrid vb.)
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=no-reply@sipariskutusu.com
EMAIL_FROM_NAME=Sipariskutusu

# ─── Sentry — Hata Takibi (isteğe bağlı) ────────────────────
# https://sentry.io → Proje → Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=https://XXXX@oXXX.ingest.sentry.io/XXXX

# ─── PostHog — Analitik (isteğe bağlı) ──────────────────────
# https://posthog.com → Project Settings → Project API Key
EXPO_PUBLIC_POSTHOG_API_KEY=phc_XXXXXXXXXXXXXXXXXXXX

# ─── Sunucu Secret'ları (otomasyon için önerilen) ───────────
# Bu alanlar local .env'de durabilir (git'e gitmez), script bunları
# Supabase secrets olarak otomatik yükler.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...
META_APP_SECRET=xxxxxxxxxxxxxxxx
META_APP_ID=123456789

# Smoke test yardimcisi (opsiyonel): Email login kapaliysa bildirim smoke icin
# aktif bir kullanicinin JWT access token degerini gecici olarak verebilirsiniz.
SMOKE_ACCESS_TOKEN=

# ─── Supabase Edge Functions Secrets (sunucu tarafı) ─────────
# Bu değerleri otomasyon scripti yükleyebilir.
# Manuel yüklemek isterseniz terminal'den ayarlayın:
#   supabase secrets set META_APP_SECRET=xxxx
# .env dosyasını asla repoya göndermeyin.

